# FinanceTracker Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=production

# Database (for Docker, use /data/finance.db)
DATABASE=finance.db

# SaaS Mode (set to true for the main SaaS platform)
SAAS_MODE=false
SAAS_DOMAIN=financetracker.app

# Stripe Configuration (for SaaS payments)
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard)
# Products -> Create Product -> Add Price
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_FAMILY_MONTHLY=price_xxx
STRIPE_PRICE_FAMILY_YEARLY=price_xxx

# Let's Encrypt email (for SSL certificates)
ACME_EMAIL=admin@example.com

# Email Ingestion Configuration
# Domain for incoming email addresses (e.g., abc123@in.financetracker.app)
EMAIL_DOMAIN=in.financetracker.app

# Email Provider Webhook Configuration
# Choose one: SendGrid, Mailgun, or Postmark
#
# SendGrid Inbound Parse:
#   1. Go to Settings -> Inbound Parse
#   2. Add host: in.financetracker.app
#   3. URL: https://yourdomain.com/api/email/inbound
#
# Mailgun Routes:
#   1. Go to Receiving -> Create Route
#   2. Match recipient: .*@in.financetracker.app
#   3. Forward: https://yourdomain.com/api/email/inbound
#
# Postmark Inbound:
#   1. Go to Servers -> Inbound
#   2. Set webhook URL: https://yourdomain.com/api/email/inbound
